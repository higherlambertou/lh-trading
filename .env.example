# Shioaji 帳號 (從永豐金 API 申請頁取得)
SHIOAJI_API_KEY=your_api_key_here
SHIOAJI_SECRET_KEY=your_secret_key_here

# CA 憑證（下單必須，純查報價可不填）
CA_PATH=/path/to/your_cert.pfx
CA_PASSWORD=your_ca_password
PERSON_ID=your_national_id

# simulation=true 為模擬模式（不會真實下單）
# 確認策略正確後改為 false 才會送到交易所（真錢！）
SIMULATION=true

# 正式啟動設 false（避免 uvicorn reload 干擾）
DEV=false

# ── 多機部署 ──────────────────────────────────────────────
# 正式盤後端綁定的 IP 與 port（main.py 使用）。
# 每台機器填自己的 IP（例如 Tailscale IP）。run_live.sh 的健康檢查也讀 BIND_HOST，
# 沒設則 fallback localhost。模擬盤固定綁 0.0.0.0:8003，不受這兩個影響。
BIND_HOST=localhost
PORT=8002

# 允許的前端來源，逗號分隔（CORS）
CORS_ORIGINS=http://localhost:3002

# 登入硬性逾時秒數（Solace 卡死時用，預設 25）
LOGIN_TIMEOUT=25
